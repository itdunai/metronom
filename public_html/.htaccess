<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Keep real files and directories untouched.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback for React Router routes like /app, /login, /register.
  RewriteRule . /index.html [L]
</IfModule>
